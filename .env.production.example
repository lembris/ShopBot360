# === Production .env — copy to .env on your server ===
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=generate-a-long-random-string-here

# Database — Postgres creates user+DB on first run (docker/postgres/init/)
POSTGRES_USER=shopbot
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=shopbot
DATABASE_URL=postgresql+asyncpg://shopbot:change-this-strong-password@postgres:5432/shopbot

# Redis (Docker internal hostnames)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# First deploy only — set true once, then false
RUN_SEED=true

# WhatsApp — Twilio recommended if no Meta access
WHATSAPP_PROVIDER=twilio
WHATSAPP_FALLBACK_PROVIDERS=wati,dialog360

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Your phone(s) allowed to use the bot (comma-separated)
ALLOWED_PHONES=+255700000000

# JWT for admin dashboard
JWT_SECRET=generate-another-long-random-string

# Optional: AI (enable docker profile "ai")
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.2

# Optional
# SENTRY_DSN=
