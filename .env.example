# App
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production

# Database (Docker creates user/db on first run — see docker/postgres/init/)
POSTGRES_USER=shopbot
POSTGRES_PASSWORD=shopbot
POSTGRES_DB=shopbot
DATABASE_URL=postgresql+asyncpg://shopbot:shopbot@localhost:5432/shopbot
RUN_SEED=true

# Redis
REDIS_URL=redis://localhost:6379/0

# WhatsApp provider (no Meta direct access required for twilio/wati/dialog360)
# Options: twilio | wati | dialog360 | meta
WHATSAPP_PROVIDER=twilio
WHATSAPP_FALLBACK_PROVIDERS=wati,dialog360,meta

# Meta Cloud API (only if WHATSAPP_PROVIDER=meta)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_API_VERSION=v21.0

# Twilio WhatsApp — https://www.twilio.com/docs/whatsapp/sandbox
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# 360dialog BSP — https://docs.360dialog.com/
DIALOG360_API_KEY=
DIALOG360_BASE_URL=https://waba-v2.360dialog.io

# WATI.io — https://docs.wati.io/
WATI_API_TOKEN=
WATI_API_BASE_URL=https://live-server.wati.io

# Auth
ALLOWED_PHONES=+255700000000
JWT_SECRET=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Rate limiting
RATE_LIMIT_PER_SECOND=5

# Ollama (Phase 2)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_SECONDS=30
AI_CONFIDENCE_THRESHOLD=0.7

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Observability
SENTRY_DSN=

# Stripe (Phase 3)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_BASIC=

# OCR (Phase 4)
TESSERACT_CMD=
